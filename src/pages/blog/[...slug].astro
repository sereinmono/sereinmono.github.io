---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixelButton from '../../components/PixelButton.astro';
import PixelIcon from '../../components/PixelIcon.astro';
import { getCollection } from 'astro:content';

// 动态路由：获取所有文章路径
export async function getStaticPaths() {
  try {
    const blogEntries = await getCollection('blog');
    return blogEntries.map(entry => ({
      params: { slug: entry.slug },
      props: { entry }
    }));
  } catch {
    // 如果内容集合不存在，返回示例文章
    return [
      {
        params: { slug: 'welcome' },
        props: {
          entry: null,
          fallbackPost: {
            title: '欢迎来到 matchafrenchfriesblog',
            description: '这是一个采用 Neo-Brutalism 风格的静态博客。',
            date: '2026-03-16',
            tags: ['博客', '介绍'],
            image: '/images/sample-1.jpg'
          }
        }
      }
    ];
  }
}

const { slug } = Astro.params;
const { entry, fallbackPost } = Astro.props;

const post = entry ? entry.data : fallbackPost;
const { Content } = entry ? await entry.render() : { Content: null };

// 格式化日期
const formattedDate = new Date(post.date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={post.title} description={post.description}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <div class="meta-item">
          <PixelIcon name="calendar" size="sm" />
          <time datetime={typeof post.date === 'string' ? post.date : post.date.toISOString()}>{formattedDate}</time>
        </div>

        {post.tags && post.tags.length > 0 && (
          <div class="post-tags">
            <PixelIcon name="tag" size="sm" />
            <div class="tags-list">
              {post.tags.map(tag => (
                <span class="nb-tag">{tag}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      <h1 class="post-title">{post.title}</h1>

      {post.image && (
        <div class="post-image nb-card">
          <img src={post.image} alt={post.title} />
        </div>
      )}
    </header>

    <div class="post-divider">
      <span class="divider-line"></span>
      <span class="divider-char">◆</span>
      <span class="divider-line"></span>
    </div>

    <div class="post-content">
      {Content ? (
        <Content />
      ) : (
        <>
          <p>这是文章的内容区域。在 Markdown 文件中编写的内容将渲染在这里。</p>
          <p>
            Neo-Brutalism 是一种现代设计风格，它重新诠释了早期网页设计的原始美学，
            通过大胆的颜色、明显的边框和简单的阴影来创造独特的视觉效果。
          </p>
          <blockquote>
            克制是一种美德。在设计中，克制的风格往往能传达更深层的意义。
          </blockquote>
          <p>
            这个博客采用米白浅灰作为主色调，深红作为点缀色，
            在保持 Neo-Brutalism 核心特征的同时，呈现出一种怀旧的温暖感。
          </p>
        </>
      )}
    </div>

    <footer class="post-footer">
      <div class="post-nav">
        <PixelButton href="/blog" variant="outline">
          ← 返回列表
        </PixelButton>
      </div>

      <div class="pixel-decoration">
        <span>■</span>
        <span>□</span>
        <span>■</span>
      </div>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
  }

  /* 文章头部 */
  .post-header {
    margin-bottom: var(--spacing-lg);
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-sm);
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .tags-list {
    display: flex;
    gap: 6px;
  }

  .post-title {
    font-size: 2.2rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: var(--spacing-md);
  }

  .post-image {
    overflow: hidden;
  }

  .post-image img {
    width: 100%;
    height: auto;
  }

  /* 分隔线 */
  .post-divider {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin: var(--spacing-lg) 0;
  }

  .divider-line {
    flex: 1;
    height: 2px;
    background-color: var(--color-border);
  }

  .divider-char {
    color: var(--color-accent);
  }

  /* 文章内容 */
  .post-content {
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4),
  .post-content :global(h5),
  .post-content :global(h6) {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-md);
    line-height: 1.4;
  }

  .post-content :global(h1) {
    font-size: 1.8rem;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
  }

  .post-content :global(h3) {
    font-size: 1.3rem;
  }

  .post-content :global(p) {
    margin-bottom: var(--spacing-md);
  }

  .post-content :global(blockquote) {
    margin: var(--spacing-lg) 0;
    padding: var(--spacing-md);
    background-color: var(--color-bg-secondary);
    border-left: 4px solid var(--color-accent);
    font-style: italic;
    color: var(--color-text-secondary);
  }

  /* 文章底部 */
  .post-footer {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-lg);
    border-top: var(--border-normal) solid var(--color-border);
  }

  .post-nav {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
  }

  .pixel-decoration {
    display: flex;
    justify-content: center;
    gap: 8px;
    font-size: 0.8rem;
    color: var(--color-accent);
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .post-title {
      font-size: 1.8rem;
    }

    .post-meta {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .post-content {
      font-size: 1rem;
    }
  }
</style>
