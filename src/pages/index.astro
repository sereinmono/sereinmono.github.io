---
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelButton from '../components/PixelButton.astro';
---

<BaseLayout title="首页">
  <section class="hero">
    <div class="hero-content">
      <div class="pixel-decoration">
        <span>■</span>
        <span>□</span>
        <span>■</span>
      </div>

      <h1 class="hero-title">
        <span class="title-line">Hello! This is </span>
        <span class="title-line title-accent">matchafrenchfries'</span>
        <span class="title-line">blog</span>
      </h1>

      <p class="hero-subtitle">
        matchafrenchfries.tech
      </p>

      <div class="hero-divider">
        <span class="divider-line"></span>
        <span class="divider-char">◆</span>
        <span class="divider-line"></span>
      </div>
    </div>
  </section>

  <section class="intro">
    <div class="intro-content">
      <p class="intro-text">
        这里是一个普通人沉淀自己思考的地方。
        <br />
        如果你如此有缘来到了这里，不妨驻足多看一会儿。
      </p>

      <div class="intro-actions">
        <PixelButton href="/blog" variant="primary">
          浏览文章
        </PixelButton>
        <PixelButton href="/about" variant="outline">
          了解更多
        </PixelButton>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="feature-grid">
      <article class="feature-item nb-card">
        <span class="pixel-counter">01</span>
        <h3>技术</h3>
        <p>就算是菜鸟也有非常想要分享的东西好吧！</p>
      </article>

      <article class="feature-item nb-card">
        <span class="pixel-counter">02</span>
        <h3>思考</h3>
        <p>个人见解，仅供参考，欢迎拨冗阅读。</p>
      </article>

      <article class="feature-item nb-card">
        <span class="pixel-counter">03</span>
        <h3>随笔</h3>
        <p>一些可能无聊，可能有趣的怪味碎碎念。</p>
      </article>
    </div>
  </section>

  <section class="pixel-footer">
    <div class="pixel-decoration-bottom">
      <span>□</span>
      <span>■</span>
      <span>□</span>
      <span>■</span>
      <span>□</span>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero 区域 - 大片留白 */
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-2xl);
  }

  .hero-content {
    text-align: center;
    max-width: 600px;
  }

  .pixel-decoration {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-bottom: var(--spacing-lg);
    font-size: 0.8rem;
    color: var(--color-accent);
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
  }

  .title-line {
    display: block;
  }

  .title-accent {
    color: var(--color-accent);
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
  }

  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
  }

  .divider-line {
    width: 60px;
    height: 2px;
    background-color: var(--color-border);
  }

  .divider-char {
    color: var(--color-accent);
    font-size: 1rem;
  }

  /* 介绍区域 */
  .intro {
    padding: var(--spacing-xl) var(--spacing-2xl);
  }

  .intro-content {
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
  }

  .intro-text {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-lg);
  }

  .intro-actions {
    display: flex;
    justify-content: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
  }

  /* 特性区域 */
  .features {
    padding: var(--spacing-xl) var(--spacing-2xl);
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    max-width: 900px;
    margin: 0 auto;
  }

  .feature-item {
    padding: var(--spacing-md);
    text-align: center;
  }

  .feature-item h3 {
    font-size: 1.1rem;
    margin: var(--spacing-sm) 0;
  }

  .feature-item p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .pixel-counter {
    font-family: var(--font-pixel);
    font-size: 1rem;
    padding: 4px 12px;
    background-color: var(--color-text-primary);
    color: var(--color-bg-primary);
    border: 2px solid var(--color-border);
    display: inline-block;
  }

  /* 底部像素装饰 */
  .pixel-footer {
    padding: var(--spacing-xl);
    text-align: center;
  }

  .pixel-decoration-bottom {
    display: flex;
    justify-content: center;
    gap: 12px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .hero {
      min-height: 50vh;
      padding: var(--spacing-lg);
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .intro {
      padding: var(--spacing-lg);
    }
  }
</style>
